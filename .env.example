# Workspace/org label shown in OmniSprint UI/header.
WORKSPACE_ORG_NAME=Your Org

# Connected engineering repository (used for issue/PR/commit lookups and links).
GITHUB_OWNER=your-org
GITHUB_REPO=your-repo
# Optional but recommended for better GitHub source access/rate limits.
GITHUB_TOKEN=

# Planning source (Google Sheets export, Jira CSV export, Linear export, or any compatible CSV URL).
PLANNING_SOURCE_KIND=google_sheet
PLANNING_SHEET_ID=
PLANNING_GID=
PLANNING_CSV_URL=
# Example:
# PLANNING_CSV_URL=https://docs.google.com/spreadsheets/d/<sheet-id>/export?format=csv&gid=<gid>
# Jira example:
# PLANNING_CSV_URL=https://your-jira-host/plugins/servlet/issueNav?jqlQuery=...&tempMax=500&csv=1

# Contributor directory source (used for owner/contributor email enrichment).
TEAM_SHEET_ID=
TEAM_GID=
TEAM_CSV_URL=

# Optional display labels surfaced in /api/health and frontend metadata.
PLANNING_SOURCE_LABEL=Planning sheet
PLANNING_SOURCE_DISPLAY_NAME=Quarterly planning sheet
TEAM_SOURCE_LABEL=Contributor directory
ENGINEERING_SOURCE_LABEL=GitHub

# Optional Coral schema/table overrides.
PLANNING_SCHEMA=planning
PLANNING_PROJECTS_TABLE=projects
PLANNING_PROJECT_LINKS_TABLE=project_links
TEAM_SCHEMA=team_context
TEAM_MEMBERS_TABLE=members

# Optional parser header overrides for non-standard CSV headers.
# Use comma-separated aliases, e.g. "Epic Name,Project,Initiative".
PLANNING_FIELD_PROJECT_TITLE=
PLANNING_FIELD_PROJECT_DESCRIPTION=
PLANNING_FIELD_OWNER_LEAD=
PLANNING_FIELD_OWNER_CONTRIBUTOR=
PLANNING_FIELD_PLANNED_DATE=
PLANNING_FIELD_SUBTASK=
PLANNING_FIELD_STATUS=
PLANNING_FIELD_ASSIGNEE=
PLANNING_FIELD_ESTIMATED_DATE=
PLANNING_FIELD_NOTES=
PLANNING_FIELD_DEBUG_LINK=

# Default 0: ingest GitHub links from any repo found in planning data.
# Set to 1 to restrict parsing to GITHUB_OWNER/GITHUB_REPO only.
GITHUB_MATCH_TARGET_REPO_ONLY=0

BACKEND_PORT=8000
FRONTEND_PORT=5173

# Omni assistant (Gemini).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OMNISPRINT_AGENT_MAX_TOOL_CALLS=5

# Optional helper for ambiguous long header rows in planning data.
OMNISPRINT_TITLE_GEMINI_ENABLED=1
OMNISPRINT_TITLE_GEMINI_MAX_CALLS=2
