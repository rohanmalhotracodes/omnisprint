# Copy this file to .env and fill in values locally or in Hugging Face Space variables/secrets.
# Never commit your populated .env file.

# Workspace label shown in the UI.
WORKSPACE_ORG_NAME=Oppia Demo

# Connected engineering repository.
GITHUB_OWNER=oppia
GITHUB_REPO=oppia
GITHUB_TOKEN=

# Optional Gemini agent settings.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OMNISPRINT_AGENT_MAX_TOOL_CALLS=5

# Planning/team CSV sources (Google Sheet/Jira/Linear exported CSV URLs).
PLANNING_CSV_URL=
TEAM_CSV_URL=

# Optional helpers to construct CSV URLs when direct URL is not supplied.
PLANNING_SHEET_ID=
PLANNING_GID=
TEAM_SHEET_ID=
TEAM_GID=

# Optional labels shown by health endpoints/UI.
PLANNING_SOURCE_LABEL=Planning sheet
PLANNING_SOURCE_DISPLAY_NAME=Quarterly planning sheet
TEAM_SOURCE_LABEL=Contributor directory
ENGINEERING_SOURCE_LABEL=GitHub

# Coral schema/table overrides.
PLANNING_SCHEMA=planning
PLANNING_PROJECTS_TABLE=projects
PLANNING_PROJECT_LINKS_TABLE=project_links
TEAM_SCHEMA=team_context
TEAM_MEMBERS_TABLE=members

# Optional parser overrides for non-standard planning headers.
PLANNING_FIELD_PROJECT_TITLE=
PLANNING_FIELD_PROJECT_DESCRIPTION=
PLANNING_FIELD_OWNER_LEAD=
PLANNING_FIELD_OWNER_CONTRIBUTOR=
PLANNING_FIELD_PLANNED_DATE=
PLANNING_FIELD_SUBTASK=
PLANNING_FIELD_STATUS=
PLANNING_FIELD_ASSIGNEE=
PLANNING_FIELD_ESTIMATED_DATE=
PLANNING_FIELD_NOTES=
PLANNING_FIELD_DEBUG_LINK=

# Port used by Hugging Face Docker Space runtime.
PORT=7860

# Local development ports.
BACKEND_PORT=8000
FRONTEND_PORT=5173

# Default 0: accept GitHub links from any repo found in planning data.
# Set to 1 to restrict to GITHUB_OWNER/GITHUB_REPO only.
GITHUB_MATCH_TARGET_REPO_ONLY=0
